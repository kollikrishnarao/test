# Polymarket Configuration
POLYMARKET_API_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=your_wallet_private_key_here

# Polygon RPC (for Chainlink oracle reads)
POLYGON_RPC_URL=https://polygon-rpc.com

# Binance API (for real-time price feeds)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Configuration
STARTING_CAPITAL=20.0
HOURLY_PROFIT_TARGET=1.0
MAX_SINGLE_TRADE_PERCENT=10
MAX_CONCURRENT_POSITIONS=6
HOURLY_LOSS_LIMIT=2.0
DAILY_LOSS_LIMIT=5.0

# Strategy Configuration
ENABLE_SPLIT_ARB=true
ENABLE_SPREAD_CAPTURE=true
ENABLE_LATE_CERTAINTY=true
ENABLE_PURE_MAKER=true
ENABLE_DIRECTIONAL=false

# Risk Management
KELLY_FRACTION=0.25
MIN_WIN_PROBABILITY=0.88
MAX_SLIPPAGE_PERCENT=0.3

# Logging
LOG_LEVEL=INFO
DATABASE_PATH=trades.db
